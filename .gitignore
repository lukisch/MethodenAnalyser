# =============================================================================
# .gitignore Template fuer Software Entwicklung Projekte
# Kopieren und als .gitignore im Projektroot ablegen
# Projektspezifische Eintraege am Ende anfuegen
# =============================================================================

# ---- Python ----
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/

# ---- Virtuelle Umgebungen ----
venv/
.venv/
env/
.env/

# ---- BACH Interne Steuerungsdateien (NIEMALS in Git!) ----
AUFGABEN.txt
TEST.txt
TESTS.txt
TESTERGEBNISSE.txt
BUGREPORT.md
DIAGNOSE_REPORT.md
SKILL.md
tmpclaude-*

# ---- Persoenliche / Sensible Daten ----
_USER/
.env
.env.*
credentials.json
client_secret*.json
token.json
*.pem
*.key
*.db
*.sqlite
*.sqlite3
keyring/

# ---- Build-Artefakte & Releases ----
releases/
*.exe
*.msi
*.msix
*.appx
*.spec
*.pfx
*.p12
*.cer

# ---- IDE & Editoren ----
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Betriebssystem ----
desktop.ini
Thumbs.db
.DS_Store
ehthumbs.db

# ---- Standard-Patterns ----
PLAN.txt
_archive/
_private/
*.log
*.tmp
*.bak

# ---- Projektspezifisch (hier eigene Eintraege anfuegen) ----
